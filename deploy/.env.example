# MongoDB
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change_me

# MongoDB — usuário de aplicação (least privilege: readWrite apenas em IngestionRefineryDb)
MONGO_APP_USERNAME=orchestrator_app
MONGO_APP_PASSWORD=change_me

# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change_me

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# Kafka — chave de assinatura HMAC para integridade das mensagens
# Gerar com: openssl rand -hex 32
KAFKA_SIGNING_KEY=
